{
  "name": "eastgate",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "clean": "rm -rf pnpm-lock.yaml node_modules .turbo && pnpm -r exec rm -rf node_modules .next dist .output .turbo"
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "turbo": "^2.9.8",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=24"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@apollo/protobufjs",
      "@nestjs/core",
      "esbuild",
      "sharp",
      "unrs-resolver"
    ]
  }
}
