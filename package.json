{
  "name": "eastgate",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "ignite": "docker compose up -d && until docker exec eastgate-local-postgres pg_isready -p 5432; do sleep 1; done && turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "codegen": "pnpm --filter @eastgate/shared codegen",
    "check-types": "turbo run check-types",
    "clean": "rm -rf pnpm-lock.yaml node_modules .turbo && pnpm -r exec rm -rf node_modules .next dist .output .turbo",
    "db:migrate": "pnpm --filter @eastgate/database db:migrate",
    "db:studio": "pnpm --filter @eastgate/database db:studio",
    "db:generate": "pnpm --filter @eastgate/database build"
  },
  "devDependencies": {
    "prettier": "^3.8.3",
    "turbo": "^2.9.8",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@11.5.3",
  "engines": {
    "node": ">=24"
  }
}
