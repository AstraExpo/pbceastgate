{
  "extends": "@eastgate/typescript-config/react-library.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./src/*"],
      "@eastgate/ui/components/*": ["./src/components/ui/*"],
      "@eastgate/ui/lib/*": ["./src/lib/*"],
      "@eastgate/ui/hooks/*": ["./src/hooks/*"],
      "@eastgate/ui/theme/*": ["./src/theme/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", ".turbo/**", "build/**", ".next/**"]
}
