datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
  output   = "../client"
}

// Responsibility: Identity, Access Control, and Spiritual/Organizational Profiles
// This group handles structural user authentication, authorization roles, and explicit records
// mapping a person's advancement or occupational standing within the church hierarchy.

enum SystemRole {
  SUPERADMIN
  ADMIN
  EDITOR
  USER
}

enum MembershipStatus {
  GUEST
  MEMBER
}

model User {
  id                    Int                 @id @default(autoincrement())
  email                 String              @unique
  passwordHash          String
  systemRole            SystemRole          @default(USER)
  membershipStatus      MembershipStatus    @default(GUEST)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  profile               Profile?
  deaconProfile         DeaconProfile?
  membershipProgress    MembershipProgress?
  staffProfile          StaffProfile?
  ledMinistries         Ministry[]          @relation("MinistryHead")
  ledDepartments        Department[]        @relation("DepartmentHead")
  ministryMemberships   MinistryMember[]
  departmentMemberships DepartmentMember[]
  orders                Order[]
  donations             Donation[]
  registrations         EventRegistration[]
  materialDonations     MaterialDonation[]
  pledges               Pledge[]
  volunteerSignUps      VolunteerSignUp[]
  prayerRequests        PrayerRequest[]
  communityPosts        CommunityPost[]     @relation("ContentAuthor")
}

model Profile {
  id          Int      @id @default(autoincrement())
  userId      Int      @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName   String
  lastName    String
  phoneNumber String?
  avatarUrl   String?
  joinedDate  DateTime @default(now())
}

model MembershipProgress {
  id                  Int       @id @default(autoincrement())
  userId              Int       @unique
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  isBaptized          Boolean   @default(false)
  completedShapeClass Boolean   @default(false)
  verifiedAt          DateTime?
}

model StaffProfile {
  id       Int      @id @default(autoincrement())
  userId   Int      @unique
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title    String
  joinedAt DateTime @default(now())
}

model DeaconProfile {
  id             Int       @id @default(autoincrement())
  userId         Int       @unique
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  ordinationDate DateTime?
  isActive       Boolean   @default(true)
  pdbRole        String?
  termStartDate  DateTime?
  termEndDate    DateTime?
}

// Responsibility: Community & Ministry Administration
// Models that govern structural governance nodes within the church ecosystem,
// including overarching ministries, broken-down internal departments, and direct member associations.

model Ministry {
  id                Int                @id @default(autoincrement())
  name              String             @unique
  description       String?            @db.Text
  headId            Int?
  head              User?              @relation("MinistryHead", fields: [headId], references: [id], onDelete: SetNull)
  departments       Department[]
  members           MinistryMember[]
  products          Product[]
  events            Event[]
  donations         Donation[]
  materialDonations MaterialDonation[]
  pledges           Pledge[]
}

model Department {
  id                Int                @id @default(autoincrement())
  name              String
  ministryId        Int
  ministry          Ministry           @relation(fields: [ministryId], references: [id], onDelete: Cascade)
  headId            Int?
  head              User?              @relation("DepartmentHead", fields: [headId], references: [id], onDelete: SetNull)
  members           DepartmentMember[]
  products          Product[]
  events            Event[]
  donations         Donation[]
  materialDonations MaterialDonation[]
  pledges           Pledge[]

  @@unique([name, ministryId])
}

model MinistryMember {
  id         Int      @id @default(autoincrement())
  ministryId Int
  parent     Ministry @relation(fields: [ministryId], references: [id], onDelete: Cascade)
  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt   DateTime @default(now())

  @@unique([ministryId, userId])
}

model DepartmentMember {
  id           Int        @id @default(autoincrement())
  departmentId Int
  parent       Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  userId       Int
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt     DateTime   @default(now())

  @@unique([departmentId, userId])
}

model PrayerRequest {
  id            Int      @id @default(autoincrement())
  userId        Int?
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  requesterName String
  content       String   @db.Text
  isPublic      Boolean  @default(false)
  isResolved    Boolean  @default(false)
  createdAt     DateTime @default(now())
}

// Responsibility: Content Management System (CMS)
// Manages social feeds, galleries, curated sermon items, series records, and notices
// deployed to inform or engage the congregation on public interfaces.

enum PostCategory {
  SUNDAY_SERVICE
  MIDWEEK_SERVICE
  MINISTRY_EVENT
  SCHOOL_EVENT
  HOUSE_GROUP
  BIBLE_STUDY
}

enum AnnouncementAudience {
  CHURCH_WIDE
  SCHOOL_ONLY
  MINISTRY_SPECIFIC
}

model CommunityPost {
  id        Int          @id @default(autoincrement())
  category  PostCategory
  title     String
  caption   String       @db.Text
  themeText String?
  mediaUrls String[]
  eventId   Int?
  event     Event?       @relation(fields: [eventId], references: [id], onDelete: SetNull)
  authorId  Int
  author    User         @relation("ContentAuthor", fields: [authorId], references: [id])
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model DailyVerse {
  id          Int      @id @default(autoincrement())
  verseLine   String
  reference   String
  publishDate DateTime @unique
  createdAt   DateTime @default(now())
}

model SermonSeries {
  id          Int      @id @default(autoincrement())
  title       String
  description String?  @db.Text
  coverUrl    String?
  createdAt   DateTime @default(now())
  sermons     Sermon[]
}

model Sermon {
  id           Int           @id @default(autoincrement())
  title        String
  description  String?       @db.Text
  videoUrl     String?
  audioUrl     String?
  thumbnailUrl String?
  preacher     String
  preachedAt   DateTime
  seriesId     Int?
  series       SermonSeries? @relation(fields: [seriesId], references: [id], onDelete: SetNull)
  slideUrls    String[]
  handoutUrls  String[]
  createdAt    DateTime      @default(now())
}

model Announcement {
  id        Int                  @id @default(autoincrement())
  title     String
  content   String               @db.Text
  posterUrl String?
  audience  AnnouncementAudience @default(CHURCH_WIDE)
  isPinned  Boolean              @default(false)
  expiresAt DateTime?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
}

// Responsibility: Events & Volunteer Infrastructure
// Handles physical or virtual gathering coordination, ticketing controls,
// partner associations, and community team rosters supporting single event projects.

enum EventScope {
  IN_HOUSE
  MINISTRY_DEPARTMENT
  COLLABORATION
}

enum RegistrationStatus {
  PENDING_PAYMENT
  CONFIRMED
  CANCELLED
}

model Event {
  id                     Int                        @id @default(autoincrement())
  title                  String
  description            String                     @db.Text
  location               String
  startsAt               DateTime
  endsAt                 DateTime
  maxCapacity            Int?
  posterUrl              String?
  scope                  EventScope                 @default(IN_HOUSE)
  price                  Decimal                    @default(0.00) @db.Decimal(10, 2)
  ministryId             Int?
  ministry               Ministry?                  @relation(fields: [ministryId], references: [id], onDelete: SetNull)
  departmentId           Int?
  department             Department?                @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  partnerId              Int?
  partner                ExternalPartner?           @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  donations              Donation[]
  materialDonations      MaterialDonation[]
  materialCampaigns      MaterialDonationCampaign[]
  pledges                Pledge[]
  registrations          EventRegistration[]
  posts                  CommunityPost[]
  products               Product[]
  volunteerOpportunities VolunteerSignUp[]
  createdAt              DateTime                   @default(now())
  updatedAt              DateTime                   @updatedAt
}

model ExternalPartner {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  contactName String?
  email       String?
  phoneNumber String?
  events      Event[]
  createdAt   DateTime @default(now())
}

model EventRegistration {
  id           Int                  @id @default(autoincrement())
  eventId      Int
  event        Event                @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId       Int
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  status       RegistrationStatus   @default(CONFIRMED)
  registeredAt DateTime             @default(now())
  transactions PaymentTransaction[]

  @@unique([eventId, userId])
}

model VolunteerSignUp {
  id            Int      @id @default(autoincrement())
  eventId       Int
  event         Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId        Int
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  preferredRole String?
  notes         String?  @db.Text
  signedUpAt    DateTime @default(now())

  @@unique([eventId, userId])
}

// Responsibility: E-Commerce Engine
// Handles structural commercial components, item tracking under discrete variants,
// procurement checkout frameworks, and explicit fulfillment configuration tracking.

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  COMPLETED
  CANCELLED
}

enum FulfillmentMethod {
  HOME_DELIVERY
  CHURCH_PICKUP
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  products Product[]
}

model Product {
  id           Int              @id @default(autoincrement())
  name         String
  description  String           @db.Text
  price        Decimal          @db.Decimal(10, 2)
  categoryId   Int
  category     Category         @relation(fields: [categoryId], references: [id])
  variants     ProductVariant[]
  orderItems   OrderItem[]
  ministryId   Int?
  ministry     Ministry?        @relation(fields: [ministryId], references: [id], onDelete: SetNull)
  departmentId Int?
  department   Department?      @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  eventId      Int?
  event        Event?           @relation(fields: [eventId], references: [id], onDelete: SetNull)
  createdAt    DateTime         @default(now())
}

model ProductVariant {
  id         Int         @id @default(autoincrement())
  productId  Int
  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku        String      @unique
  size       String?
  color      String?
  stockCount Int         @default(0)
  orderItems OrderItem[]
}

model Order {
  id                Int                  @id @default(autoincrement())
  userId            Int?
  user              User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  status            OrderStatus          @default(PENDING)
  totalAmount       Decimal              @db.Decimal(10, 2)
  fulfillmentMethod FulfillmentMethod    @default(CHURCH_PICKUP)
  shippingAddress   String?              @db.Text
  trackingNumber    String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  items             OrderItem[]
  transactions      PaymentTransaction[]
}

model OrderItem {
  id               Int             @id @default(autoincrement())
  orderId          Int
  order            Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId        Int
  product          Product         @relation(fields: [productId], references: [id])
  productVariantId Int?
  variant          ProductVariant? @relation(fields: [productVariantId], references: [id])
  quantity         Int
  priceAtPurchase  Decimal         @db.Decimal(10, 2)
}

// Responsibility: Financial Ledger, Donations & Pledging
// Manages all monetary and non-monetary giving pipelines, target asset drives,
// strategic multi-part pledges, and the unified transactional logging for M-Pesa STK push.

enum FinancialPurpose {
  TITHE
  OFFERING
  GENERAL_FUND_ALLOCATION
}

enum PledgeStatus {
  PENDING
  PARTIALLY_FULFILLED
  FULFILLED
  CANCELLED
}

enum MaterialCategory {
  FOOD
  CLOTHES
  EQUIPMENT
  OTHER
}

model DonationCampaign {
  id          Int        @id @default(autoincrement())
  title       String
  description String     @db.Text
  targetGoal  Decimal?   @db.Decimal(12, 2)
  isActive    Boolean    @default(true)
  donations   Donation[]
  pledges     Pledge[]
  createdAt   DateTime   @default(now())
}

model Donation {
  id              Int                  @id @default(autoincrement())
  userId          Int?
  user            User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  campaignId      Int?
  campaign        DonationCampaign?    @relation(fields: [campaignId], references: [id])
  purpose         FinancialPurpose     @default(GENERAL_FUND_ALLOCATION)
  amount          Decimal              @db.Decimal(12, 2)
  isAnonymous     Boolean              @default(false)
  ministryId      Int?
  ministry        Ministry?            @relation(fields: [ministryId], references: [id], onDelete: SetNull)
  departmentId    Int?
  department      Department?          @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  eventId         Int?
  event           Event?               @relation(fields: [eventId], references: [id], onDelete: SetNull)
  isSchoolProject Boolean              @default(false)
  pledgeId        Int?
  pledge          Pledge?              @relation(fields: [pledgeId], references: [id], onDelete: SetNull)
  transactions    PaymentTransaction[]
  createdAt       DateTime             @default(now())
}

model MaterialDonationCampaign {
  id          Int                            @id @default(autoincrement())
  title       String
  description String                         @db.Text
  isActive    Boolean                        @default(true)
  eventId     Int?
  event       Event?                         @relation(fields: [eventId], references: [id], onDelete: SetNull)
  items       MaterialDonationCampaignItem[]
  donations   MaterialDonation[]
  createdAt   DateTime                       @default(now())

  @@map("MaterialDonationCampaign")
}

model MaterialDonationCampaignItem {
  id                 Int                      @id @default(autoincrement())
  materialCampaignId Int
  campaign           MaterialDonationCampaign @relation(fields: [materialCampaignId], references: [id], onDelete: Cascade)
  itemName           String
  targetQuantity     Int
  unit               String

  @@map("MaterialDonationCampaignItem")
}

model MaterialDonation {
  id                 Int                       @id @default(autoincrement())
  userId             Int?
  user               User?                     @relation(fields: [userId], references: [id], onDelete: SetNull)
  category           MaterialCategory
  itemDescription    String                    @db.Text
  quantityText       String
  dropOffDate        DateTime?
  isReceived         Boolean                   @default(false)
  materialCampaignId Int?
  materialCampaign   MaterialDonationCampaign? @relation(fields: [materialCampaignId], references: [id], onDelete: SetNull)
  ministryId         Int?
  ministry           Ministry?                 @relation(fields: [ministryId], references: [id], onDelete: SetNull)
  departmentId       Int?
  department         Department?               @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  eventId            Int?
  event              Event?                    @relation(fields: [eventId], references: [id], onDelete: SetNull)
  isSchoolProject    Boolean                   @default(false)
  pledgeId           Int?
  pledge             Pledge?                   @relation(fields: [pledgeId], references: [id], onDelete: SetNull)
  createdAt          DateTime                  @default(now())
}

model Pledge {
  id                 Int                @id @default(autoincrement())
  userId             Int
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  status             PledgeStatus       @default(PENDING)
  dueDate            DateTime?
  pledgedAmount      Decimal?           @db.Decimal(12, 2)
  monetaryDonations  Donation[]
  pledgedItemName    String?
  pledgedItemQty     Int?
  pledgedItemUnit    String?
  materialDonations  MaterialDonation[]
  donationCampaignId Int?
  donationCampaign   DonationCampaign?  @relation(fields: [donationCampaignId], references: [id], onDelete: SetNull)
  ministryId         Int?
  ministry           Ministry?          @relation(fields: [ministryId], references: [id], onDelete: SetNull)
  departmentId       Int?
  department         Department?        @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  eventId            Int?
  event              Event?             @relation(fields: [eventId], references: [id], onDelete: SetNull)
  isSchoolProject    Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
}

model PaymentTransaction {
  id                  Int                @id @default(autoincrement())
  gateway             String
  checkoutRequestId   String             @unique
  merchantRequestId   String
  reference           String?            @unique
  status              String
  amount              Decimal            @db.Decimal(12, 2)
  rawGatewayResponse  String?            @db.Text
  orderId             Int?
  order               Order?             @relation(fields: [orderId], references: [id], onDelete: SetNull)
  donationId          Int?
  donation            Donation?          @relation(fields: [donationId], references: [id], onDelete: SetNull)
  eventRegistrationId Int?
  eventRegistration   EventRegistration? @relation(fields: [eventRegistrationId], references: [id], onDelete: SetNull)
  createdAt           DateTime           @default(now())
}

// Responsibility: Communications & Auditing
// Disconnected logging models configured to capture analytical interaction history,
// user outbound message metrics, and external mailing list profiles.

model EmailSubscriber {
  id           Int      @id @default(autoincrement())
  email        String   @unique
  isActive     Boolean  @default(true)
  subscribedAt DateTime @default(now())
}

model NotificationLog {
  id        Int      @id @default(autoincrement())
  recipient String
  title     String
  body      String   @db.Text
  sentType  String
  status    String
  sentAt    DateTime @default(now())
}
