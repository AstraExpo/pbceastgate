{
  "extends": "@eastgate/typescript-config/base.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": ["src/**/*", "codegen.ts"],
  "exclude": [
    "node_modules",
    "dist/**",
    ".turbo/**",
    "build/**",
    ".next/**"
  ]
}
